# Project Rampart - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME=Project Rampart
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# ============================================
# Security Keys (CHANGE THESE!)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
KEY_ENCRYPTION_SECRET=your-key-encryption-secret-change-in-production

# ============================================
# Database Configuration
# ============================================
# Local uvicorn / tests (Postgres on host)
DATABASE_URL=postgresql://rampart:YOUR_SECURE_PASSWORD@localhost:5432/rampart
#
# docker compose: bundled Postgres uses POSTGRES_PASSWORD below; optional host port overrides if busy:
# POSTGRES_PUBLISH_PORT=5433
# REDIS_PUBLISH_PORT=6380
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
#
# Only if the API container must use Postgres *outside* Compose (host/other host):
# COMPOSE_DATABASE_URL=postgresql://rampart:YOUR_SECURE_PASSWORD@host.docker.internal:5432/rampart
#
# Bootstrap user/db on a non-Compose Postgres once:
#   psql -U postgres -h localhost -f backend/api/migrations/00_init_rampart_database.sql

# SQLite (Local Development - will be used if DATABASE_URL not set)
# DATABASE_URL=sqlite:///./rampart_dev.db

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
# Tools on the host talking to Compose Redis when REDIS_PUBLISH_PORT=6380:
# REDIS_URL=redis://localhost:6380/0

# ============================================
# LLM Provider API Keys
# ============================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ============================================
# Security Settings
# ============================================
# Content Filtering
MAX_TOKEN_LIMIT=4096
ENABLE_PII_DETECTION=true
ENABLE_TOXICITY_DETECTION=true
TOXICITY_THRESHOLD=0.7

# GLiNER PII model — options: edge (default, fastest, 197MB ONNX), balanced, accurate
# edge   → knowledgator/gliner-pii-edge-v1.0  — F1 75.5%, UINT8 ONNX 197MB
# balanced → knowledgator/gliner-pii-small-v1.0 — F1 76.8%, FP16 ONNX ~330MB
# accurate → knowledgator/gliner-pii-base-v1.0  — F1 81.0%, FP16 ONNX ~330MB
PII_MODEL_TYPE=edge
PII_USE_ONNX=true

# Toxicity model: unitary/toxic-bert (BERT-base, multi-label Jigsaw fine-tune)
# 6 labels: toxic, severe_toxic, obscene, threat, insult, identity_hate
# ~420 MB, well-calibrated — no false positives on common short phrases.
# Replaces old heuristic word-list and citizenlab/distilbert (had false positives).
# Set ENABLE_TOXICITY_DETECTION=false to skip loading the model entirely.

# Observability
ENABLE_TRACING=true
ENABLE_METRICS=true
TRACE_SAMPLE_RATE=1.0
# OTLP gRPC endpoint (optional). TLS is used unless you set the insecure flag for local dev only.
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
# OTEL_EXPORTER_OTLP_INSECURE=true

# add_demo_api_key.py only: full Rampart key to register (never commit real values)
# DEMO_RAMPART_API_KEY=rmp_live_...

# Policy Engine
DEFAULT_POLICY_MODE=monitor
ENABLE_AUTO_REMEDIATION=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Super-Admin Access
# ============================================
# Comma-separated list of email addresses with super-admin privileges.
# These accounts can access GET /api/v1/admin/stats and /admin/users.
# Leave empty to disable super-admin endpoints entirely.
# Example: SUPER_ADMIN_EMAILS=you@example.com,ops@company.com
SUPER_ADMIN_EMAILS=

# ============================================
# Audit Logging
# ============================================
# Set to false if you ship access logs to your own SIEM / log aggregator
# (Datadog, Splunk, CloudWatch, etc.) and don't want Rampart writing them
# to the database. The /admin/stats request-volume metrics will be empty
# when this is off, but all other admin data (users, API keys) still works.
# Default: true
AUDIT_LOG_ENABLED=true

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Development default: http://localhost:3000,http://localhost:3001
# Production example: https://rampart-ai.vercel.app,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================
# Optional: External Services
# ============================================
# Sentry (Error Tracking)
# SENTRY_DSN=your-sentry-dsn

# Prometheus (Metrics)
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Slack (Alerts)
# SLACK_WEBHOOK_URL=your-slack-webhook-url

# Email (Notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
